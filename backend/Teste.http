### 1. health check — só pra confirmar que o servidor está de pé
GET http://localhost:3001/api/health

### 2. login — precisamos do token para tudo mais
POST http://localhost:3001/api/auth/login
Content-Type: application/json

{
  "email": "admin@teste.com",
  "senha": "password"
}

### 3. criar organização (troca SEU_TOKEN pelo token que vier no login)
POST http://localhost:3001/api/organizacoes
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiZW1haWwiOiJhZG1pbkB0ZXN0ZS5jb20iLCJpYXQiOjE3NzU1MTQ1NjcsImV4cCI6MTc3NTYwMDk2N30.Equt6ue7ua9PkAhE6wv4S_ydl0NOM-631QYDpax1xIw

{
  "nome": "Minha Org Teste"
}

### 4. listar minhas organizações
GET http://localhost:3001/api/organizacoes
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiZW1haWwiOiJhZG1pbkB0ZXN0ZS5jb20iLCJpYXQiOjE3NzU1MTQ1NjcsImV4cCI6MTc3NTYwMDk2N30.Equt6ue7ua9PkAhE6wv4S_ydl0NOM-631QYDpax1xIw

### 5. criar quadro (troca o organizacaoId pelo id que vier na resposta do passo 3)
POST http://localhost:3001/api/quadros
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiZW1haWwiOiJhZG1pbkB0ZXN0ZS5jb20iLCJpYXQiOjE3NzU1MTQ1NjcsImV4cCI6MTc3NTYwMDk2N30.Equt6ue7ua9PkAhE6wv4S_ydl0NOM-631QYDpax1xIw

{
  "organizacaoId": 1,
  "nome": "Meu Quadro Teste",
  "descricao": "Testando"
}